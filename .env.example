# -----------------------------------------------------------------------------
# All API keys for this app are entered by the user in the sidebar UI at runtime
# and are sent only to this app's own backend routes (never stored, never
# committed). No keys are strictly required at deploy time.
#
# The variables below are OPTIONAL. If set, they are used as server-side
# fallback defaults so you (or an evaluator) don't have to paste keys in every
# session. Anything typed into the UI always overrides these.
# -----------------------------------------------------------------------------

# OpenRouter API key (https://openrouter.ai/keys)
# Used for AI reasoning: company summaries, pain points, competitor analysis.
OPENROUTER_API_KEY=

# Serper.dev API key (https://serper.dev)
# Used for search: finding the official site, contact info, and competitors.
SERPER_API_KEY=

# Default AI model to preselect in the dropdown (any OpenRouter model slug)
NEXT_PUBLIC_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# Discord bot integration (bonus feature) — optional server-side defaults
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
